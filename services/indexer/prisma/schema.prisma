generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auctions ───────────────────────────────────────────

model Auction {
  id               String        @id @default(cuid())
  mint             String        @unique
  ticker           String
  /// Solana wallet address that created this coin. This is the
  /// canonical creator-of-record and MUST be populated. It is the
  /// sole recipient of the 80% creator fee share.
  creator          String
  startTime        DateTime
  endTime          DateTime
  totalSol         BigInt        @default(0)
  totalSupply      BigInt
  participantCount Int           @default(0)
  state            AuctionState  @default(GATHERING)
  uniformPrice     BigInt?
  stakeReturned    Boolean       @default(false)
  raydiumPoolId    String?
  /// Share of total_supply distributed to batch buyers (in real bps).
  /// 6500 = 65%. The rest seeds the Raydium pool. Snapshot at creation
  /// time so later admin changes don't retroactively affect this auction.
  buyerBps         Int           @default(6500)
  /// True once the pool's share of tokens + all committed SOL have been
  /// released to the crank for Raydium pool creation.
  poolSeeded       Boolean       @default(false)
  tokenName        String?
  tokenImage       String?
  description      String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  creatorRel  Creator      @relation(fields: [creator], references: [wallet])
  commitments Commitment[]
  swaps       Swap[]
  quests      Quest[]
  stake       Stake?

  @@index([creator])
  @@index([state])
  @@index([ticker])
}

enum AuctionState {
  GATHERING
  SUCCEEDED
  FAILED
  TRADING
}

// ─── Commitments ────────────────────────────────────────

model Commitment {
  id            String   @id @default(cuid())
  auctionMint   String
  wallet        String
  solAmount     BigInt
  tokensClaimed Boolean  @default(false)
  createdAt     DateTime @default(now())

  auction Auction @relation(fields: [auctionMint], references: [mint])

  @@unique([auctionMint, wallet])
  @@index([wallet])
}

// ─── Swaps ──────────────────────────────────────────────

model Swap {
  id            String   @id @default(cuid())
  auctionMint   String
  wallet        String
  isBuy         Boolean
  solAmount     BigInt
  tokenAmount   BigInt
  creatorFee    BigInt
  protocolFee   BigInt
  price         BigInt
  signature     String   @unique
  timestamp     DateTime

  auction Auction @relation(fields: [auctionMint], references: [mint])

  @@index([auctionMint, timestamp])
  @@index([wallet, timestamp])
  @@index([wallet])
}

// ─── Stakes ─────────────────────────────────────────────

model Stake {
  id                String     @id @default(cuid())
  auctionMint       String     @unique
  creator           String
  amount            BigInt
  milestoneDeadline DateTime
  state             StakeState @default(ESCROWED)
  evaluatedAt       DateTime?
  createdAt         DateTime   @default(now())

  auction Auction @relation(fields: [auctionMint], references: [mint])

  @@index([creator])
  @@index([state])
}

enum StakeState {
  ESCROWED
  RETURNED
  FORFEITED
  EMERGENCY_WITHDRAWN
}

// ─── Ticker Registry ────────────────────────────────────

model TickerEntry {
  id           String   @id @default(cuid())
  ticker       String   @unique
  mint         String   @unique
  registeredAt DateTime @default(now())
  ttlExpiry    DateTime
  active       Boolean  @default(true)

  @@index([active])
}

// ─── Holder Snapshots ───────────────────────────────────

model HolderSnapshot {
  id          String   @id @default(cuid())
  mint        String
  wallet      String
  balance     BigInt
  firstSeen   DateTime
  lastUpdated DateTime @default(now())

  @@unique([mint, wallet])
  @@index([mint])
  @@index([wallet])
}

// ─── Prove Scores ───────────────────────────────────────

model ProveScore {
  id                    String   @id @default(cuid())
  wallet                String   @unique
  score                 Int      @default(0)
  totalHoldTimeHours    Float    @default(0)
  auctionsParticipated  Int      @default(0)
  questContributions    Int      @default(0)
  earlyDumpRatio        Float    @default(0)
  lastActive            DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ─── Quests ─────────────────────────────────────────────

model Quest {
  id          String    @id @default(cuid())
  auctionMint String
  type        QuestType
  target      Int
  current     Int       @default(0)
  completed   Boolean   @default(false)
  completedAt DateTime?
  reward      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  auction Auction @relation(fields: [auctionMint], references: [mint])

  @@unique([auctionMint, type])
  @@index([completed])
}

enum QuestType {
  X_POSTS
  HOLDER_COUNT
  HOLD_TIME
  PRICE_ABOVE_BATCH
  GRADUATION
}

// ─── Creator Fee Tracking ───────────────────────────────

model CreatorFee {
  id              String   @id @default(cuid())
  mint            String
  creator         String
  totalEarned     BigInt   @default(0)
  totalWithdrawn  BigInt   @default(0)
  lastUpdated     DateTime @updatedAt

  @@unique([mint, creator])
  @@index([creator])
  @@index([mint])
}

// ─── Forfeit Pool ───────────────────────────────────────

model ForfeitPool {
  id               String   @id @default(cuid())
  totalForfeited   BigInt   @default(0)
  lastDistribution DateTime?
  updatedAt        DateTime @updatedAt
}

// ─── Creators ───────────────────────────────────────────
//
// One row per unique creator wallet. Created the first time a wallet
// launches a coin (upserted from the listener when AuctionCreated lands,
// or earlier from the launch flow when the user hits POST /api/creators).
// Every Auction FKs into this table, so the creator address is a hard
// database invariant — you cannot insert an auction without one.

model Creator {
  wallet       String   @id
  /// Privy user id (e.g. did:privy:...) if the user logged in via Privy.
  /// Nullable because an auction can still be indexed from a pure
  /// wallet-only user, but we try to set it on launch.
  privyUserId  String?  @unique
  email        String?
  handle       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auctions Auction[]

  @@index([privyUserId])
}

// ─── Protocol Config (singleton) ────────────────────────
//
// Single row (id = 1) that pins the protocol-wide invariants:
//   - the 80/20 creator/protocol fee split
//   - the protocol vault address (where taxes go)
//
// A CHECK constraint in migration 002 enforces creatorBps = 80 and
// protocolBps = 20, so the split cannot drift from what the on-chain
// fee-router enforces. The indexer asserts this row exists and matches
// at boot — if not, it refuses to start.

model ProtocolConfig {
  id                   Int      @id @default(1)
  creatorBps           Int      // MUST be 80
  protocolBps          Int      // MUST be 20
  protocolVaultAddress String   // Solana address receiving the 20% tax
  updatedAt            DateTime @updatedAt
}
