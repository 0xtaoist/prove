{
  "name": "@prove/indexer",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "prisma migrate deploy && node dist/index.js",
    "lint": "eslint src/",
    "test": "vitest run",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "db:seed": "tsx ../../scripts/db-seed.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@prisma/client": "^6.0.0",
    "@prove/common": "workspace:*",
    "@raydium-io/raydium-sdk-v2": "0.2.39-alpha",
    "@solana/web3.js": "^1.95.0",
    "bn.js": "^5.2.3",
    "cors": "^2.8.5",
    "decimal.js": "^10.6.0",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/bn.js": "^5.2.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "eslint": "^9.0.0",
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
