# ─── Solana ─────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

# ─── Program IDs ─────────────────────────────────────────
# Populated automatically by scripts/deploy-devnet.sh into
# .env.programs. The indexer (listener + swap indexer) skips
# startup if any of these are missing or invalid.
BATCH_AUCTION_PROGRAM_ID=
FEE_ROUTER_PROGRAM_ID=
STAKE_MANAGER_PROGRAM_ID=

# ─── Protocol Vault (receives the 20% protocol fee share) ──
# REQUIRED. The indexer refuses to start if this is missing or if
# the ProtocolConfig row still holds the placeholder value.
PROTOCOL_VAULT_ADDRESS=

# ─── Database (Railway provides this) ──────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/prove

# ─── Next.js App ───────────────────────────────────────
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_INDEXER_URL=http://localhost:4000
# Privy app id + secret (from https://dashboard.privy.io). Required in production.
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=
PORT=3000

# ─── Frontend Program IDs (NEXT_PUBLIC_ prefix exposes to browser) ──
NEXT_PUBLIC_BATCH_AUCTION_PROGRAM_ID=
NEXT_PUBLIC_STAKE_MANAGER_PROGRAM_ID=
NEXT_PUBLIC_FEE_ROUTER_PROGRAM_ID=

# ─── Indexer ───────────────────────────────────────────
INDEXER_PORT=4000
NODE_ENV=development
# Optional: Redis URL for distributed rate limiting across replicas.
# If not set, rate limiting uses in-memory store (single-instance only).
REDIS_URL=

# ─── Quest Verifier ───────────────────────────────────
QUEST_PORT=4001
# Shared secret for internal service-to-service calls (indexer → quest-verifier).
# Required in production; set to a random string (e.g. `openssl rand -hex 32`).
INTERNAL_API_KEY=
# CORS: explicit origin for API services (e.g. https://prove.example.com)
APP_ORIGIN=
# Path to the Solana keypair file used by crank and init-programs scripts
ANCHOR_WALLET=~/.config/solana/id.json
X_API_BEARER_TOKEN=
TELEGRAM_BOT_TOKEN=
# Raydium CLMM AMM config key (required for pool creation script)
RAYDIUM_CLMM_AMM_CONFIG_ID=
