{
  "name": "prove",
  "private": true,
  "scripts": {
    "dev:app": "pnpm --filter @prove/app dev",
    "dev:indexer": "pnpm --filter @prove/indexer dev",
    "dev:quest": "pnpm --filter @prove/quest-verifier dev",
    "build:app": "pnpm --filter @prove/common build && pnpm --filter @prove/app build",
    "build:indexer": "pnpm --filter @prove/common build && pnpm --filter @prove/indexer build",
    "build:quest": "pnpm --filter @prove/common build && pnpm --filter @prove/quest-verifier build",
    "build:all": "pnpm --filter @prove/common build && pnpm -r --filter '!@prove/common' run build",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "db:migrate": "pnpm --filter @prove/indexer db:migrate",
    "db:generate": "pnpm --filter @prove/indexer db:generate"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "neverBuiltDependencies": [
      "usb",
      "tiny-secp256k1",
      "blake-hash"
    ]
  }
}
